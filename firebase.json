{
  "hosting": {
    "site": "plus-pi",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebase",
      ".gitignore",
      "DESIGN_SYSTEM.md",
      "README.md",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
